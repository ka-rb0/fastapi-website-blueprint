# Copy this file to .devcontainer/.env and adjust the values for your machine.
LOG_LEVEL="INFO"
DATA_PATH="/mnt/data"
CLAUDE_HOME_HOST_PATH="<your_claude_home_host_path>"
CODEX_HOME_HOST_PATH="<your_codex_home_host_path>"
# The dev server is only reachable from this machine by default. Uncomment to
# expose it to your LAN (e.g. to test from a phone on the same network):
# WEBSITE_BIND_HOST="0.0.0.0"
# Interactive API docs at /docs - on by default in the dev container.
# Uncomment to turn them off:
# WEBSITE_ENABLE_DOCS=0
WEBSITE_EXTERNAL_PORT=11110
WEBSITE_INTERNAL_PORT=11111
WEBSITE_TEST_PORT=11112
