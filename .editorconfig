# Cross-editor defaults for contributors whose editors don't run the toolchain.
# The values deliberately match what the formatters enforce.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.py]
indent_size = 4

[*.md]
# a trailing double-space is a hard line break in Markdown - don't strip it
trim_trailing_whitespace = false
