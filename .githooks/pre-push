#!/bin/sh
# Blocks a push to any branch unless the checks CI runs (see
# .github/workflows/ci.yml) pass locally: scripts/lint + scripts/test.
# The security audits that need network access (pip-audit, npm audit,
# zizmor's online audits) are not run here - run scripts/audit for those.
# Tag pushes and deletion-only pushes are not guarded - they introduce no
# new code to check.
#
# Committed hooks are not active by default; activate once per clone with:
#   git config core.hooksPath .githooks
#
# Emergency bypass (use sparingly): git push --no-verify
#
# Known tradeoff: the checks run against the working tree, not the commits
# being pushed, so uncommitted changes can mask a broken commit or block a
# clean one. Deliberate: checking the real commits would mean stashing or a
# temp worktree, and stash-and-restore hooks are fragile. CI verifies the
# actual commits anyway - this is just a fast local backstop.

zero_sha="0000000000000000000000000000000000000000"

# stdin: one line per ref being pushed: <local ref> <local sha> <remote ref> <remote sha>
pushing_commits=""
while read -r _local_ref local_sha remote_ref _remote_sha; do
  case "$remote_ref" in
    refs/heads/*)
      if [ "$local_sha" != "$zero_sha" ]; then
        pushing_commits=1
      fi
      ;;
  esac
done
[ -z "$pushing_commits" ] && exit 0

echo "pre-push: running scripts/lint + scripts/test (bypass: --no-verify)"

cd "$(git rev-parse --show-toplevel)" || exit 1

# scripts/lint keeps going and reports everything wrong in one pass; the
# slower test suite only runs once lint is clean.
if ! scripts/lint || ! scripts/test; then
  echo ""
  echo "pre-push: checks failed - push aborted." >&2
  exit 1
fi

echo ""
echo "pre-push: all checks passed - pushing."
exit 0
