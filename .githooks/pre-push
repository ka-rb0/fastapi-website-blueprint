#!/bin/sh
# Blocks a push to main unless the checks CI runs (see
# .github/workflows/ci.yml) pass locally: scripts/lint + scripts/test.
# The CI security audits (pip-audit, npm audit, zizmor) are not run here -
# they need network access. Pushes to other branches are not guarded - CI
# covers them via pull_request.
#
# Committed hooks are not active by default; activate once per clone with:
#   git config core.hooksPath .githooks
#
# Emergency bypass (use sparingly): git push --no-verify

# stdin: one line per ref being pushed: <local ref> <local sha> <remote ref> <remote sha>
pushing_main=""
while read -r _local_ref _local_sha remote_ref _remote_sha; do
  if [ "$remote_ref" = "refs/heads/main" ]; then
    pushing_main=1
  fi
done
[ -z "$pushing_main" ] && exit 0

echo "pre-push: push targets main - running scripts/lint + scripts/test (bypass: --no-verify)"

cd "$(git rev-parse --show-toplevel)" || exit 1

# scripts/lint keeps going and reports everything wrong in one pass; the
# slower test suite only runs once lint is clean.
if ! scripts/lint || ! scripts/test; then
  echo ""
  echo "pre-push: checks failed - push to main aborted." >&2
  exit 1
fi

echo ""
echo "pre-push: all checks passed - pushing to main."
exit 0
